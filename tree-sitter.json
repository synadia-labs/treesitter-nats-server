{
  "grammars": [
    {
      "name": "nats_server_conf",
      "camelCase": "natsServerConf",
      "scope": "source.nats-server-conf",
      "injection-regex": "nats[_-](?:server[_-])?conf",
      "path": ".",
      "file-types": [
        "conf",
        { "suffix": ".conf.j2" },
        { "suffix": ".conf.jinja" },
        { "suffix": ".conf.jinja2" },
        { "suffix": ".conf.gotmpl" },
        { "suffix": ".conf.erb" }
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "folds": "queries/folds.scm",
      "indents": "queries/indents.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.2",
    "license": "MIT",
    "description": "Tree-sitter grammar for NATS server configuration files",
    "authors": [
      {
        "name": "Phil Pennock"
      }
    ],
    "links": {
      "repository": "https://github.com/synadia-labs/treesitter-nats-server"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
